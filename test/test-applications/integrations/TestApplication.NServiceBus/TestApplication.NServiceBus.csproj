<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net10.0;net9.0;net8.0</TargetFrameworks>
    <TargetFrameworks Condition="'$(OS)' == 'Windows_NT'">$(TargetFrameworks);net472</TargetFrameworks>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(TargetFramework)' == 'net10.0' and '$(LibraryVersion)' == '' ">
    <UseNServiceBusHostedEndpoint>true</UseNServiceBusHostedEndpoint>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(TargetFramework)' == 'net10.0' and '$(LibraryVersion)' != '' and '$(LibraryVersion)' &gt;= '10.2.0' ">
    <UseNServiceBusHostedEndpoint>true</UseNServiceBusHostedEndpoint>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(UseNServiceBusHostedEndpoint)' == 'true' ">
    <DefineConstants>$(DefineConstants);NSERVICEBUS_HOSTED_ENDPOINT</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Condition=" '$(UseNServiceBusHostedEndpoint)' == 'true' " />
    <PackageReference Include="NServiceBus" VersionOverride="$(LibraryVersion)" Condition=" '$(LibraryVersion)' != '' or ('$(TargetFramework)' != 'net472' and '$(TargetFramework)' != 'net9.0' and '$(TargetFramework)' != 'net8.0' ) " />
    <PackageReference Include="NServiceBus" VersionOverride="9.2.12" Condition=" '$(LibraryVersion)' == '' and ( '$(TargetFramework)' == 'net9.0' or '$(TargetFramework)' == 'net8.0' ) " />
    <PackageReference Include="NServiceBus" VersionOverride="8.2.7" Condition=" '$(LibraryVersion)' == '' and '$(TargetFramework)' == 'net472' " />
    <PackageReference Include="System.Security.Cryptography.Xml" Condition=" '$(TargetFramework)' == 'net472' or ( '$(LibraryVersion)' != '' and  '$(LibraryVersion)' &lt;= '9.0.0' )" />
  </ItemGroup>

</Project>
